# 数据库连接(默认 SQLite)
# DB_URL=sqlite:///db.sqlite3

# 向量检索设备: auto | cpu | cuda
RAG_DEVICE=auto

# GPU 下启用半精度加速
RAG_USE_FP16=true

# 检索参数
RAG_BATCH_SIZE=8
RAG_MAX_LENGTH=8192
RAG_RETRIEVAL_TOP_K=20
RAG_RETRIEVAL_MIN_SCORE=0.2
RAG_POOLING=cls

# 严格分数门槛:召回低于 min_score 时不回退硬塞结果(交给关键词兜底)
RAG_STRICT_THRESHOLD=true

# query 前缀(BGE-M3 实测无需,保留兼容部分 BGE 系列)
# RAG_QUERY_PREFIX=query:

# CPU 推理线程数(0 表示用 torch 默认)
RAG_TORCH_NUM_THREADS=4

# CPU 下 INT8 动态量化(opt-in,需 eval 验证质量不降后再开)
# RAG_INT8_QUANTIZE=false

# 索引持久化缓存(冷启动加速:全量编码 ~6s → 缓存加载 ~0.02s)
# RAG_CACHE_DIR_REL=cache
# RAG_CACHE_DISABLED=false

# 模型路径(留空则自动检测 models/ 目录,否则用 HuggingFace repo ID)
# RAG_EMBEDDING_MODEL=BAAI/bge-m3

# ---- 网页正文提取(fetcher) ----
# 基于 httpx + trafilatura,无 API 依赖。
FETCHER_CONCURRENCY=6
FETCHER_MAX_URLS=20
FETCHER_MIN_CHARS=80
FETCHER_CONNECT_TIMEOUT=8
FETCHER_READ_TIMEOUT=20
FETCHER_SSRF_ENABLED=true
# SSRF 白名单 CIDR(逗号分隔)。生产留空=最严;开发机走 fake-ip 代理时设:
# FETCHER_ALLOWED_IPS=198.18.0.0/15

# ---- LLM(报单智能整合等后台任务) ----
# LLM_API_KEY=your_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen3.5-flash
